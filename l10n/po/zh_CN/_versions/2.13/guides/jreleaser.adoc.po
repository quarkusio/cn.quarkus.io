#. type: Title =
#: _versions/2.13/guides/jreleaser.adoc
#, no-wrap
msgid "Bootstrapping the project"
msgstr "创建项目"

#. type: Plain text
#: _versions/2.13/guides/jreleaser.adoc
#, fuzzy
