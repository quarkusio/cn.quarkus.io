#. type: Block title
#. mt: deepl
#: _versions/3.34/guides/getting-started-testing.adoc
#, fuzzy
msgid "Maven"
msgstr "Maven"

#. type: Block title
#. mt: deepl
#: _versions/3.34/guides/getting-started-testing.adoc
#, fuzzy
msgid "Gradle"
