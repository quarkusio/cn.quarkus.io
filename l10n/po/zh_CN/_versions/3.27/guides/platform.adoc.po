msgstr "`generate-extensions-json` 是用于生成平台描述符的目标"

#. type: Plain text
#: _versions/3.27/guides/platform.adoc
#, fuzzy
msgid "the `groupId` of the platform BOM"
msgstr "平台 BOM 的 `groupId`"

#. type: Plain text
#: _versions/3.27/guides/platform.adoc
#, fuzzy
msgid "the `artifactId` of the platform BOM"
msgstr "平台 BOM 的 `artifactId`"

#. type: Plain text
#: _versions/3.27/guides/platform.adoc
#, fuzzy
