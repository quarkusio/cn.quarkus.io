#. type: Plain text
#: _versions/3.20/guides/http-reference.adoc
#, fuzzy
msgid "`disabled`"
msgstr "`已禁用`"

#. type: Plain text
#: _versions/3.20/guides/http-reference.adoc
#, fuzzy
