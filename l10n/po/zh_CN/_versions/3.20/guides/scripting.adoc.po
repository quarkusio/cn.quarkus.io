#. type: Title =
#: _versions/3.20/guides/scripting.adoc
#, fuzzy
msgid "Debugging"
msgstr "调试"

#. type: Plain text
#: _versions/3.20/guides/scripting.adoc
#, fuzzy
msgid ""
"To debug the application you use `jbang --debug quarkusapp.java` and you can use your IDE to connect on port 4004; if you want to use the\n"
