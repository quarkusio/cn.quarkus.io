msgstr "订阅命令（ `SUBSCRIBE` 、 `UNSUBSCRIBE` 等）"

#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/redis-reference.adoc
#, fuzzy
msgid "`SELECT`"
msgstr "`SELECT`"

#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/redis-reference.adoc
#, fuzzy
