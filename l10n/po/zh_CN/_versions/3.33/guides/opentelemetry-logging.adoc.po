#: _versions/3.33/guides/opentelemetry-logging.adoc
#, fuzzy
msgid "Using OpenTelemetry Logging"
msgstr "使用 OpenTelemetry 日志记录"

#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/opentelemetry-logging.adoc
#, fuzzy
msgid "<a class=\"status-label status-preview\" title=\"This extension's backward compatibility and presence in the ecosystem is not guaranteed\" href=\"#extension-status-note\">preview</a>"
msgstr "<a class=\"status-label status-preview\" title=\"无法保证此扩展程序的向后兼容性及其在生态系统中的可用性\" href=\"#extension-status-note\">预览</a>"

#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/opentelemetry-logging.adoc
#, fuzzy
msgid "This guide explains how your Quarkus application can utilize https://opentelemetry.io/[OpenTelemetry] (OTel) to provide structured, contextual, vendor-neutral and centralised logging for interactive web applications."
msgstr "本指南介绍了您的 Quarkus 应用程序如何利用 link:https://opentelemetry.io/[OpenTelemetry] （OTel）为交互式 Web 应用程序提供结构化、上下文相关、厂商中立且集中的日志记录功能。"

#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/opentelemetry-logging.adoc
#, fuzzy
msgid "This document is part of the xref:observability.adoc[Observability in Quarkus reference guide] which features this and other observability related components."
msgstr "本文档是《 xref:observability.adoc[Quarkus 可观测性参考指南] 》的一部分，该指南介绍了本组件以及其他与可观测性相关的组件。"

#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/opentelemetry-logging.adoc
#, fuzzy
msgid "OpenTelemetry Logging is considered _tech preview_ and is disabled by default."
msgstr "OpenTelemetry 日志记录目前处于 _技术预览_ 阶段，默认处于禁用状态。"

#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/opentelemetry-logging.adoc
#, fuzzy
msgid "The xref:opentelemetry.adoc[OpenTelemetry Guide] is available with signal independent information about the OpenTelemetry extension."
msgstr "《 xref:opentelemetry.adoc[OpenTelemetry 指南] 》提供了关于 OpenTelemetry 扩展的、与信号无关的信息。"

