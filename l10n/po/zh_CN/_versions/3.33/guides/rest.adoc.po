msgstr "类 `org.acme.one.Model`"

#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/rest.adoc
#, fuzzy
msgid "The class `org.acme.two.Model`"
msgstr "类 `org.acme.two.Model`"

#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/rest.adoc
