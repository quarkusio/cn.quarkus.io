#. type: Title =
#. mt: deepl
#: _versions/3.33/guides/getting-started-reactive.adoc
#, fuzzy
msgid "Reactive Panache Entity"
msgstr "反应型风采实体"

#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/getting-started-reactive.adoc
#, fuzzy
msgid "Let's start with the `Fruit` entity.Create the `src/main/java/org/acme/hibernate/orm/panache/Fruit.java` file with the following content:"
msgstr "我们先从 `Fruit` 实体开始。创建 `src/main/java/org/acme/hibernate/orm/panache/Fruit.java` 文件，内容如下："

