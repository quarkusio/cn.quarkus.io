#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/mongodb.adoc
#, fuzzy
msgid "xref:#dev-services[Dev Services for MongoDB] is your best option to start a MongoDB database for your unit tests."
msgstr "xref:dev-services[MongoDB 开发服务] 是您为单元测试创建 MongoDB 数据库的最佳选择。"

#. type: Plain text
