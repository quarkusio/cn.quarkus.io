#. type: Plain text
#. mt: deepl
#: _versions/3.33/guides/security-webauthn.adoc
#, fuzzy
msgid "`GET /q/webauthn/logout`: Logs you out"
msgstr "`GET /q/webauthn/logout` ：注销"

#. type: Plain text
#. mt: deepl
