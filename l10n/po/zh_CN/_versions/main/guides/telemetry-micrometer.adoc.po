#: _versions/main/guides/telemetry-micrometer.adoc
#, fuzzy
msgid "Enable JSON metrics"
msgstr "启用 JSON 指标"

#. type: Plain text
#: _versions/main/guides/telemetry-micrometer.adoc
#, fuzzy
