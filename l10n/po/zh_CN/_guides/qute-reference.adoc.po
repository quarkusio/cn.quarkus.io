#: _guides/qute-reference.adoc
#, fuzzy, no-wrap
msgid "`#if` Section Example"
msgstr "`#if` 章节示例"

#. type: Plain text
#: _guides/qute-reference.adoc
#, fuzzy
msgid "This is the main block."
msgstr "这是主体部分。"

#. type: Plain text
