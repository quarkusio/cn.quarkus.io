#, fuzzy
msgid "https://quarkus.io/guides/rest-client[quarkus-rest-client]"
msgstr "link:https://quarkus.io/guides/rest-client[quarkus-rest-client]"

#. type: Plain text
#: _guides/proxy-registry.adoc
#, fuzzy
msgid "https://quarkus.io/guides/redis[quarkus-redis-client]"
msgstr "link:https://quarkus.io/guides/redis[quarkus-redis-client]"

#. type: Plain text
#: _guides/proxy-registry.adoc
#, fuzzy
msgid "https://pt.quarkus.io/guides/smallrye-graphql-client[quarkus-smallrye-graphql-client]"
msgstr "link:https://pt.quarkus.io/guides/smallrye-graphql-client[quarkus-smallrye-graphql-client]"

#. type: Plain text
